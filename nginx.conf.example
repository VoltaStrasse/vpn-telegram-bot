# Пример конфигурации nginx для проксирования вебхуков NowPayments
# Замените volttecc.com на ваш домен, а пути к сертификатам – на ваши.

server {
    listen 8443 ssl;
    server_name volttecc.com;  # замените на ваш домен

    ssl_certificate /etc/letsencrypt/live/volttecc.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/volttecc.com/privkey.pem;

    # Проксирование запросов к /webhook на внутренний сервер
    location /webhook {
        proxy_pass http://127.0.0.1:8081;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # (опционально) другие location, если нужно
}